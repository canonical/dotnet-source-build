Description: Replace comm/sort to avoid rust-coreutils regression
 This patch replaces the usage of comm/sort to avoid a core-utils-related
 regression from happening on Ubuntu 26.04.
Author: Mateus Rodrigues de Morais <mateus.morais@canonical.com>
Forwarded: not-needed
Last-Update: 2026-03-10
---
===================================================================
Index: src/emsdk/eng/build.sh
===================================================================
--- a/src/emsdk/eng/build.sh
+++ b/src/emsdk/eng/build.sh
@@ -65,7 +65,19 @@ checkedPossibleDirectoryToBuild=false
 
 # Check if an action is passed in
 declare -a actions=("r" "restore" "b" "build" "buildtests" "rebuild" "t" "test" "pack" "sign" "publish" "clean")
-actInt=($(comm -12 <(printf '%s\n' "${actions[@]/#/-}" | sort) <(printf '%s\n' "${@/#--/-}" | sort)))
+actInt=()
+for a in "$@"; do
+  a="${a/#--/-}"
+  a="$(printf '%s' "$a" | awk '{print tolower($0)}')"
+  a="${a#-}"
+
+  for act in "${actions[@]}"; do
+    if [[ "$a" == "$act" ]]; then
+      actInt+=("-$act")
+      break
+    fi
+  done
+done
 
 while [[ $# > 0 ]]; do
   opt="$(echo "${1/#--/-}" | awk '{print tolower($0)}')"
